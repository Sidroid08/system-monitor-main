PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-secure-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

DATABASE_URL="mysql://app_user:replace-with-local-db-value@localhost:3306/sidroid"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sidroid
DB_USER=app_user
DB_PASSWORD=replace-with-local-db-value
DB_CONNECTION_LIMIT=10

AWS_DEFAULT_REGION=us-east-1
AWS_SYNC_DEFAULT_REGION=us-east-1

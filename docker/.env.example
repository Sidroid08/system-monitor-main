# Copy this file to docker/.env locally and fill in real values.
# Never commit docker/.env or any real cloud credentials.

AWS_ACCESS_KEY_ID=replace-with-your-local-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-local-secret-access-key
AWS_REGION=us-east-1

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-local-password
